{
    "urn": "vcfa:plugin:quick-start",
    "name": "Quick Start Plugin",
    "containerVersion": "9.1.0",
    "manifestVersion": "6.0.0",
    "version": "0.0.0",
    "scope": [
        "service-provider",
        "tenant"
    ],
    "permissions": [],
    "description": "Quick Start Plugin based on Angular and Clarity UI",
    "vendor": "Broadcom",
    "license": "BSD-2-Clause",
    "link": "https://broadcom.com",
    "extensionPoints": [
        {
            "urn": "urn:vcfa:plugin:quick-start:primary-navigation",
            "type": "navigation:primary",
            "name": "%example.localization.primary.navigation%",
            "description": "%example.localization.description%",
            "exposes": "Navigation",
            "component": "SubnavComponent",
            "componentSelector": "plugin-subnav",
            "route": "primary-quickstart",
            "icon": "assets/plugin.png"
        },
        {
            "urn": "urn:vcfa:plugin:quick-start:services:overview",
            "type": "navigation:services:overview",
            "name": "%example.localization.overview%",
            "description": "%example.localization.description%",
            "exposes": "Navigation",
            "component": "SubnavComponent",
            "componentSelector": "plugin-subnav",
            "route": "overview-quickstart",
            "iconShape": "quick-start-icon",
            "iconShapeSrc": "custom-icons-folder/my-custom-icon.svg"
        },
        {
            "urn": "urn:vcfa:plugin:quick-start:services:vcf",
            "type": "navigation:services:vcf",
            "name": "%example.localization.vcf.service%",
            "description": "%example.localization.description%",
            "exposes": "Navigation",
            "component": "SubnavComponent",
            "componentSelector": "plugin-subnav",
            "route": "vcf-service-quickstart",
            "iconShape": "quick-start-icon",
            "iconShapeSrc": "custom-icons-folder/my-custom-icon.svg"
        },
        {
            "urn": "urn:vcfa:plugin:quick-start:manage:govern",
            "type": "navigation:manage:govern",
            "name": "%example.localization.manage.govern%",
            "description": "%example.localization.description%",
            "exposes": "Navigation",
            "component": "SubnavComponent",
            "componentSelector": "plugin-subnav",
            "route": "manage-govern-quickstart",
            "iconShape": "quick-start-icon",
            "iconShapeSrc": "custom-icons-folder/my-custom-icon.svg"
        }
    ],
    "locales": {
        "en": {
            "example.localization.primary.navigation": "Partner Services Extension Point",
            "example.localization.overview": "Overview Extension Point",
            "example.localization.vcf.service": "VCF Services Extension Point",
            "example.localization.manage.govern": "Manage Govern Extension Point",
            "example.localization.description": "Example of description for the extension point"
        }
    }
}