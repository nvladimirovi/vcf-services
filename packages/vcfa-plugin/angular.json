{
	"$schema": "./node_modules/@angular/cli/lib/config/schema.json",
	"version": 1,
	"newProjectRoot": "projects",
	"projects": {
		"ui-plugin": {
			"projectType": "application",
			"schematics": {
				"@schematics/angular:component": {
					"style": "scss"
				}
			},
			"root": "projects/ui-plugin",
			"sourceRoot": "projects/ui-plugin/src",
			"prefix": "app",
			"architect": {
				"build": {
					"builder": "ngx-build-plus:browser",
					"options": {
						"outputPath": "dist/quick-start",
						"index": "projects/ui-plugin/src/index.html",
						"polyfills": [
							"zone.js"
						],
						"tsConfig": "projects/ui-plugin/tsconfig.app.json",
						"inlineStyleLanguage": "scss",
						"assets": [
							{
								"glob": "**/*",
								"input": "projects/ui-plugin/public",
								"output": "."
							}
						],
						"styles": [
							"projects/ui-plugin/src/styles.scss"
						],
						"scripts": [],
						"main": "projects/ui-plugin/src/main.ts",
						"extraWebpackConfig": "projects/ui-plugin/webpack.config.js",
						"commonChunk": false
					},
					"configurations": {
						"production": {
							"budgets": [
								{
									"type": "initial",
									"maximumWarning": "500kB",
									"maximumError": "1MB"
								},
								{
									"type": "anyComponentStyle",
									"maximumWarning": "4kB",
									"maximumError": "8kB"
								}
							],
							"outputHashing": "all",
							"extraWebpackConfig": "projects/ui-plugin/webpack.prod.config.js"
						},
						"development": {
							"optimization": false,
							"extractLicenses": false,
							"sourceMap": true
						},
						"plugin": {
							"outputPath": "dist/ui-plugin",
							"styles": [],
							"budgets": [
								{
									"type": "initial",
									"maximumWarning": "500kB",
									"maximumError": "1MB"
								},
								{
									"type": "anyComponentStyle",
									"maximumWarning": "4kB",
									"maximumError": "8kB"
								}
							],
							"outputHashing": "all",
							"extraWebpackConfig": "projects/ui-plugin/webpack.prod.config.js"
						}
					},
					"defaultConfiguration": "development"
				},
				"serve": {
					"builder": "ngx-build-plus:dev-server",
					"configurations": {
						"production": {
							"buildTarget": "ui-plugin:build:production",
							"extraWebpackConfig": "projects/ui-plugin/webpack.prod.config.js"
						},
						"development": {
							"buildTarget": "ui-plugin:build:development"
						}
					},
					"defaultConfiguration": "development",
					"options": {
						"port": 4401,
						"publicHost": "http://localhost:4401",
						"extraWebpackConfig": "projects/ui-plugin/webpack.config.js"
					}
				},
				"test": {
					"builder": "@angular-devkit/build-angular:karma",
					"options": {
						"polyfills": [
							"zone.js",
							"zone.js/testing"
						],
						"tsConfig": "projects/ui-plugin/tsconfig.spec.json",
						"inlineStyleLanguage": "scss",
						"assets": [
							{
								"glob": "**/*",
								"input": "projects/ui-plugin/public"
							}
						],
						"styles": [
							"projects/ui-plugin/src/styles.scss"
						],
						"scripts": []
					}
				}
			}
		}
	}
}